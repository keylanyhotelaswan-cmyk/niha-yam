# Supabase Cloud — copy from Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Local setup only — never commit, never bundle in frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Isolated Testing: see docs/testing-environment.md
# Schema: pnpm migrate:schema  (Production + Testing)
# Seed:   pnpm seed:testing    (Testing ONLY — never Production)
# Run:    pnpm env:testing && pnpm migrate:schema && pnpm seed:testing && pnpm dev:testing
#
# migrate:testing needs SUPABASE_DB_PASSWORD in .env.testing
# (Dashboard → Project Settings → Database → Database password)
